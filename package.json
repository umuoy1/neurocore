{
  "name": "neurocore",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:meta": "npm run build && node --test tests/meta-benchmark.test.mjs tests/meta-metacognition.test.mjs tests/hardening-meta.test.mjs",
    "test:unit": "npm run build && node --test tests/*.test.mjs --test-name-pattern \"^(?!.*baseline-llm)\"",
    "test:hosted": "npm run build && node --test tests/hosted-productization.test.mjs tests/eval-api.test.mjs",
    "test:baseline": "npm run build && node --test tests/baseline-llm.test.mjs",
    "test:coverage": "npm run build && node --test --experimental-test-coverage tests/*.test.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "demo:session": "npm run build && node examples/demo-session.mjs",
    "demo:high-risk": "npm run build && node examples/demo-high-risk-change.mjs",
    "demo:incident": "npm run build && node examples/demo-incident-diagnosis.mjs",
    "demo:cli": "npm run build && node examples/demo-cli.mjs",
    "demo:claude-code": "npm run build && node examples/claude-code-cli.mjs",
    "demo:replay": "npm run build && node examples/demo-replay.mjs",
    "demo:eval": "npm run build && node examples/demo-eval.mjs",
    "benchmark:longmemeval": "npm run build && node examples/demo-longmemeval-benchmark.mjs",
    "benchmark:meta": "npm run build && node examples/demo-meta-benchmark.mjs",
    "benchmark:meta:compare": "npm run build && node examples/demo-meta-benchmark-compare.mjs",
    "benchmark:longmemeval:full": "npm run build && node examples/demo-longmemeval-full-benchmark.mjs",
    "benchmark:longmemeval:generate": "npm run build && node examples/demo-longmemeval-generate-hypotheses.mjs",
    "benchmark:longmemeval:official:retrieval": "npm run build && node examples/demo-longmemeval-official-retrieval.mjs",
    "benchmark:longmemeval:official:qa": "npm run build && node examples/demo-longmemeval-official-qa-eval.mjs",
    "demo:checkpoint": "npm run build && node examples/demo-checkpoint.mjs",
    "demo:goals": "npm run build && node examples/demo-goal-decomposition.mjs",
    "demo:memory": "npm run build && node examples/demo-cross-session-memory.mjs",
    "demo:predictor": "npm run build && node examples/demo-predictor-approval.mjs",
    "demo:policy": "npm run build && node examples/demo-policy-block.mjs",
    "demo:semantic": "npm run build && node examples/demo-semantic-memory.mjs",
    "demo:skills": "npm run build && node examples/demo-skill-match.mjs",
    "demo:events": "npm run build && node examples/demo-runtime-events.mjs",
    "demo:tool-retry": "npm run build && node examples/demo-tool-retry.mjs",
    "demo:runtime-server": "npm run build && node examples/demo-runtime-server.mjs",
    "demo:runtime-concurrency": "npm run build && node examples/demo-runtime-concurrency.mjs",
    "demo:runtime-cleanup": "npm run build && node examples/demo-runtime-cleanup.mjs",
    "demo:runtime-modes": "npm run build && node examples/demo-runtime-modes.mjs",
    "demo:runtime-sqlite": "npm run build && node examples/demo-runtime-sqlite.mjs",
    "demo:webhooks": "npm run build && node examples/demo-runtime-webhooks.mjs",
    "demo:runtime-parity": "npm run build && node examples/demo-runtime-parity.mjs",
    "demo:runtime-recovery": "npm run build && node examples/demo-runtime-recovery.mjs",
    "demo:world-model": "npm run build && node examples/demo-world-model.mjs",
    "demo:personal-assistant:web": "npm run build && node examples/personal-assistant/scripts/dev-web-chat.mjs",
    "demo:personal-assistant:feishu": "npm run build && node examples/personal-assistant/scripts/dev-feishu.mjs",
    "console:backend": "npm run build && node examples/console-backend.mjs",
    "console:dev": "npm run build && concurrently \"node examples/console-backend.mjs\" \"npm --workspace @neurocore/console run dev\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.2"
  }
}
